<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Translator.Desktop.ViewModels"
        xmlns:models="using:Translator.Desktop.Models"
        x:Class="Translator.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="680" Height="780" MinWidth="520" MinHeight="540"
        Title="Translate">
    <Grid Margin="28,20,28,16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" MaxWidth="680">

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource TranslateIcon}" Width="22" Height="22"
                          Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="Translate" FontSize="19" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Classes="pill" VerticalAlignment="Center">
                    <TextBlock Text="auto-detect" FontSize="12.5" Foreground="{DynamicResource MutedBrush}"/>
                </Border>
                <ToggleButton Classes="icon" IsChecked="{Binding ShowSettings}" ToolTip.Tip="Settings">
                    <PathIcon Data="{StaticResource TuneIcon}"/>
                </ToggleButton>
            </StackPanel>
        </DockPanel>

        <!-- Settings -->
        <Border Grid.Row="1" Classes="card" Padding="18" Margin="0,0,0,16"
                IsVisible="{Binding ShowSettings}">
            <StackPanel Spacing="6">
                <TextBlock Text="Writing style" FontSize="13" FontWeight="Medium"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBox Classes="field" Text="{Binding StyleText}" TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="78" Margin="0,0,0,10"/>
                <TextBlock Text="Anthropic API Key" FontSize="13" FontWeight="Medium"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBox Classes="field" Text="{Binding ApiKeyText}" PasswordChar="•"/>
                <TextBlock FontSize="12.5" Foreground="{DynamicResource FaintBrush}" TextWrapping="Wrap"
                           Margin="0,4,0,0"
                           Text="The key is stored only on this machine and sent straight to Anthropic."/>
            </StackPanel>
        </Border>

        <!-- Input -->
        <Border Grid.Row="2" Classes="card" Padding="16,4,8,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Classes="bare" Text="{Binding InputText}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="88" MaxHeight="220" VerticalContentAlignment="Top"
                         PlaceholderText="Type in any language…" KeyDown="OnInputKeyDown"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Bottom" Margin="8,0,0,4">
                    <Button Classes="icon" Command="{Binding ClearInputCommand}" ToolTip.Tip="Clear">
                        <PathIcon Data="{StaticResource CloseIcon}"/>
                    </Button>
                    <Button Classes="primary" Command="{Binding TranslateCommand}" IsEnabled="{Binding !IsBusy}">
                        <Panel>
                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding !IsBusy}">
                                <PathIcon Data="{StaticResource ArrowIcon}" Width="17" Height="17"/>
                                <TextBlock Text="Translate" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Translating…" IsVisible="{Binding IsBusy}" VerticalAlignment="Center"/>
                        </Panel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Target languages -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding Languages}" Margin="0,14,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:LanguageOption">
                    <ToggleButton Classes="chip" IsChecked="{Binding IsChecked}" Content="{Binding Label}"
                                  Margin="0,0,8,8"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Error -->
        <Border Grid.Row="4" Classes="card" Padding="18,14" Margin="0,8,0,0" IsVisible="{Binding HasError}">
            <TextBlock Text="{Binding Error}" Foreground="{StaticResource ErrorBrush}"
                       FontSize="14" TextWrapping="Wrap"/>
        </Border>

        <!-- History head -->
        <DockPanel Grid.Row="5" Margin="4,18,4,10" IsVisible="{Binding HasHistory}">
            <TextBlock DockPanel.Dock="Left" Text="TRANSLATIONS" FontSize="12" FontWeight="SemiBold"
                       LetterSpacing="0.6" Foreground="{DynamicResource FaintBrush}" VerticalAlignment="Center"/>
            <Button HorizontalAlignment="Right" Classes="icon small" Command="{Binding ClearHistoryCommand}"
                    ToolTip.Tip="Clear history" Width="NaN" Padding="8,0">
                <TextBlock Text="clear" FontSize="12" Foreground="{DynamicResource FaintBrush}"/>
            </Button>
        </DockPanel>

        <!-- History -->
        <ScrollViewer Grid.Row="6" IsVisible="{Binding HasHistory}">
            <ItemsControl ItemsSource="{Binding Recents}" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:HistoryItem">
                        <Border Classes="card" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel Spacing="10">
                                <Border Classes="dir" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Dir}"/>
                                </Border>
                                <Grid ColumnDefinitions="*,Auto,*">
                                    <Grid Grid.Column="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Input}" TextWrapping="Wrap"
                                                   FontSize="15" LineHeight="23" Margin="0,4,6,0"
                                                   Foreground="{DynamicResource MutedBrush}"/>
                                        <Button Grid.Column="1" Classes="icon small" VerticalAlignment="Top"
                                                ToolTip.Tip="Copy original"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CopyCommand}"
                                                CommandParameter="{Binding Input}">
                                            <PathIcon Data="{StaticResource CopyIcon}"/>
                                        </Button>
                                    </Grid>
                                    <Border Grid.Column="1" Width="1" Margin="12,2"
                                            Background="{DynamicResource LineBrush}"/>
                                    <Grid Grid.Column="2" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Translation}" TextWrapping="Wrap"
                                                   FontSize="15" LineHeight="23" FontWeight="Medium" Margin="0,4,6,0"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <Button Grid.Column="1" Classes="icon small" VerticalAlignment="Top"
                                                ToolTip.Tip="Copy translation"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CopyCommand}"
                                                CommandParameter="{Binding Translation}">
                                            <PathIcon Data="{StaticResource CopyIcon}"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
